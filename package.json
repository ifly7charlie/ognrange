{
    "name": "ognrange",
    "private": true,
    "scripts": {
        "dev": "NODE_OPTIONS='--inspect --enable-source-maps ' next dev",
        "aprs": "node --enable-source-maps dist/bin/aprs.js",
        "build": "yarn aprs:build && yarn next build",
        "aprs:build": "tsc --project tsconfig-bin.json",
        "dumpdb": "node --enable-source-maps dist/bin/dumpdb.js",
        "dumparrow": "node --enable-source-maps dist/bin/dumparrow.js",
        "reconcile": "node --enable-source-maps dist/bin/reconcile.js",
        "export": "next export",
        "start": "next start",
        "lint": "next lint",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "aprs:dev": "tsc-watch --project tsconfig-bin.json --onFailure \"echo Failed build\" --onSuccess \"node  --enable-source-maps --inspect --experimental-fetch dist/bin/aprs.js\"",
        "aprs:devbrk": "tsc-watch --project tsconfig-bin.json --onFailure \"echo Failed build\" --onSuccess \"node  --enable-source-maps --inspect-brk --experimental-fetch dist/bin/aprs.js\""
    },
    "dependencies": {
        "@loaders.gl/arrow": "^4.3.4",
        "@loaders.gl/json": "^4.3.4",
        "@mapbox/tilebelt": "^1.0.2",
        "apache-arrow": "^18.0.0",
        "async-lock": "^1.4.0",
        "classic-level": "^3.0.0",
        "deck.gl": "^9.2.11",
        "dotenv": "^16.0.0",
        "h3-js": "^4.1.0",
        "i18next": "^25.6.3",
        "js-aprs-fap": "^1.1.5",
        "js-aprs-is": "^1.0.6",
        "lodash": "^4.17.23",
        "lru-cache": "^7.17.0",
        "mapbox-gl": "^2.15.0",
        "ndarray": "^1.0.19",
        "next": "15.5.12",
        "next-i18next": "15.4.3",
        "pngjs": "^6.0.0",
        "react": "^18.0.0",
        "react-bootstrap": "^2.1.2",
        "react-colorful": "^5.6.1",
        "react-dock": "^0.5.1",
        "react-dom": "^18.0.0",
        "react-i18next": "^16.3.5",
        "react-icons": "^4.3.1",
        "react-map-gl": "^8.1.0",
        "react-select": "^5.7.7",
        "react-visibility-sensor": "^5.1.1",
        "recharts": "^2.1.12",
        "swr": "^2.2.4",
        "yargs": "^17.3.1"
    },
    "devDependencies": {
        "@types/async-lock": "^1.4.0",
        "@types/node": "^18.11.9",
        "@types/yargs": "^17.0.0",
        "@vitest/coverage-v8": "^4.0.18",
        "esm": "^3.2.25",
        "prettier": "^2.7.1",
        "ts-node": "^10.9.1",
        "tsc-watch": "^6.2.1",
        "typescript": "^5.1.0",
        "vitest": "^4.0.18"
    },
    "resolutions": {
        "lodash": "^4.17.23",
        "fast-xml-parser": "^4.5.4",
        "diff": "^4.0.4",
        "@types/mapbox-gl": "3.4.1"
    }
}
